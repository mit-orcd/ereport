# Copy to /etc/ereport/ecrawl-daily.conf and adjust paths.
#
# RSYNC_DEST — Parent on another machine (or local path) that receives *crawl output*. Each job’s
#     output_dir is mirrored to DEST/<basename(output_dir)>/. Example: output_dir
#     /var/lib/ecrawl/server-a → RSYNC_DEST/server-a/. Use RSYNC_DEST only when you want sync;
#     every mirrored job needs a non-empty output_dir column (TAB-separated).
#
# Syntax:
#   - Lines before ---jobs--- are directives: KEY=value
#   - After ---jobs---, one crawl per line, TAB-separated:
#       start_path — directory ecrawl walks
#       output_dir — where crawl output is written on *this* host (required if you use RSYNC_DEST);
#                    parent dirs are created if missing (mkdir -p); on a failed run known ecrawl
#                    artifact filenames under output_dir may be deleted (see ecrawl-daily.sh header).
#       record_root — optional --record-root; empty → omit --record-root
#     Empty middle/right columns still need tabs (e.g. path<TAB><TAB>).

ECRAWL_BIN=/opt/ereport/ecrawl

RSYNC_DEST=backup.example.com:/var/lib/ereport-crawl/

# Optional: remote shell for rsync (same -e as rsync)
# RSYNC_RSH=ssh -o BatchMode=yes -o StrictHostKeyChecking=accept-new
# RSYNC_DELETE=1

# --- jobs (TAB-separated: start_path, output_dir, record_root) ---
---jobs---
/mnt/server-a/data	/var/lib/ecrawl/server-a	
/mnt/server-b/home	/var/lib/ecrawl/server-b	/mnt/server-b/home
